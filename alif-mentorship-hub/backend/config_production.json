{
  "api_endpoints": {
    "version": "v1",
    "base_path": "/api",
    "auth_endpoints": {
      "login": "/api/v1/auth/login/",
      "register": "/api/v1/auth/register/",
      "refresh": "/api/v1/auth/refresh/",
      "logout": "/api/v1/auth/logout/",
      "profile": "/api/v1/auth/profile/"
    },
    "user_endpoints": {
      "mentors": "/api/v1/mentors/",
      "students": "/api/v1/students/",
      "applications": "/api/v1/applications/"
    },
    "session_endpoints": {
      "sessions": "/api/v1/sessions/",
      "reviews": "/api/v1/reviews/",
      "messages": "/api/v1/messages/"
    }
  },
  "frontend": {
    "base_url": "https://alifmentorship.com",
    "api_timeout": 30000,
    "retry_attempts": 3,
    "cache_duration": 600000,
    "supported_file_types": [
      "image/jpeg",
      "image/png",
      "image/gif",
      "application/pdf",
      "text/plain",
      "application/msword",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
    ],
    "max_file_size": 10485760
  },
  "security": {
    "cors_origins": [
      "https://alifmentorship.com",
      "https://www.alifmentorship.com"
    ],
    "csrf_trusted_origins": [
      "https://alifmentorship.com",
      "https://www.alifmentorship.com"
    ],
    "allowed_hosts": [
      "alifmentorship.com",
      "www.alifmentorship.com",
      "api.alifmentorship.com"
    ],
    "rate_limits": {
      "anon": "50/hour",
      "user": "500/hour",
      "login": "3/minute",
      "register": "2/minute"
    },
    "jwt_expiry": 1800,
    "refresh_expiry": 259200
  },
  "database": {
    "engine": "django.db.backends.mysql",
    "name": "alif_mentorship_prod",
    "host": "localhost",
    "port": "3306",
    "user": "alif_user",
    "password": "",
    "options": {
      "charset": "utf8mb4",
      "sql_mode": "STRICT_TRANS_TABLES",
      "isolation_level": "read committed"
    }
  },
  "features": {
    "messaging_enabled": true,
    "file_upload_enabled": true,
    "notifications_enabled": true,
    "analytics_enabled": true,
    "caching_enabled": true,
    "rate_limiting_enabled": true
  },
  "integrations": {
    "email_service": "smtp",
    "storage_service": "aws_s3",
    "monitoring_service": "sentry",
    "analytics_service": "google_analytics"
  }
}